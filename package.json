{
  "name": "veridion-swe",
  "version": "1.0.0",
  "description": "Veridion SWE Challenge — Company Data API with scraping, matching, and analytics",
  "type": "module",
  "main": "dist/api/index.js",
  "scripts": {
    "dev": "tsx watch src/api/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "scrape": "tsx src/scraper/index.ts",
    "analyze": "tsx src/analysis/report.ts",
    "pipeline": "tsx src/pipeline/index.ts",
    "seed:supabase": "tsx src/pipeline/seed-supabase.ts",
    "seed:elasticsearch": "tsx src/pipeline/index-elasticsearch.ts",
    "api": "tsx src/api/index.ts",
    "test:match-rate": "tsx src/analysis/match-test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bogdansys/veridion-swe.git"
  },
  "keywords": [
    "scraping",
    "elasticsearch",
    "matching",
    "company-data"
  ],
  "author": "Bogdan",
  "license": "ISC",
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.1",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.99.0",
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "libphonenumber-js": "^1.12.38",
    "p-limit": "^7.3.0",
    "playwright": "^1.58.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "vitest": "^4.0.18"
  }
}
